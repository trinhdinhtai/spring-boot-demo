{
    "realm": "chopper-realm",
    "enabled": true,
    "registrationAllowed": true,
    "registrationEmailAsUsername": false,
    "clients": [
        {
            "clientId": "nuxt-frontend",
            "enabled": true,
            "publicClient": true,
            "standardFlowEnabled": true,
            "directAccessGrantsEnabled": true,
            "redirectUris": [
                "http://localhost:3000/*"
            ],
            "webOrigins": [
                "http://localhost:3000"
            ]
        },
        {
            "clientId": "spring-backend",
            "enabled": true,
            "bearerOnly": true
        }
    ],
    "roles": {
        "realm": [
            {
                "name": "USER"
            },
            {
                "name": "ADMIN"
            }
        ]
    }
}